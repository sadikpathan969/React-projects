{
  "expo": {
    "name": "Todo list",
    "slug": "todo-list",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/newlogo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/newlogo.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.todolist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#4A90E2"
      },
      "package": "com.yourname.todolist"
    },
    "web": {
      "favicon": "./assets/images/newlogo.png"
    },
    "plugins": [
      ["expo-av"]
    ]
  }
}
